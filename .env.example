# ============================================
# Universal .env Template for PFA Project
# ============================================
# Copy this file to .env and fill in your actual values

# Backend & Database
SECRET_KEY=replace_with_a_strong_random_secret
DATABASE_URL=postgresql://pfa_user:pfa_password@localhost:5432/pfa_db

# PostgreSQL (used by docker-compose)
POSTGRES_DB=pfa_db
POSTGRES_USER=pfa_user
POSTGRES_PASSWORD=pfa_password

# LLM & AI APIs
GEMINI_API_KEY=replace_with_your_gemini_api_key
GROQ_API_KEY=replace_with_your_groq_api_key

# LangSmith Evaluation & Tracing
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=replace_with_your_langsmith_api_key
LANGSMITH_PROJECT=pfa
